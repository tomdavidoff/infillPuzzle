+                 complete.cases(choiceDT[, ..needed]) &
+                 is.finite(permitLogArea) &
+                 is.finite(logBcaLandPPSF)]
> cat(sprintf("\nEstimation sample: n = %d  (duplex = %d, SF = %d)\n",
