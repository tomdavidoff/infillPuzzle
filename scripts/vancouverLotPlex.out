> # vancouverLotPlex.R
> # 33 vs 50 price gap, duplex takeup, and spatial averaging
> # Tom Davidoff
> # 05/05/26
> #
> # Spec:
> #   - FSR 0.5-0.8, age 1-39, year 2014-2018
> #   - 3rd-order polynomial in logFSR
> #   - Universal sample dtSalesRegSubset for all hedonics
> #   - Permits restricted to 33' lots (the duplex-vs-SFH margin)
> 
> library(DBI)
> library(RSQLite)
> library(data.table)
> library(fixest)
> library(ggplot2)
> library(sf)
Linking to GEOS 3.13.0, GDAL 3.8.5, PROJ 9.5.1; sf_use_s2() is TRUE
> 
> # ============================================================================
> # ---- Permits ---------------------------------------------------------------
> # ============================================================================
> permitFile <- "~/DropboxExternal/dataRaw/issued-building-permits.csv"
> dtPermit <- fread(permitFile, select = c("PermitNumber","ProjectValue","TypeOfWork", "PropertyUse","SpecificUseCategory", "GeoLocalArea","geo_point_2d","YearMonth"))
> 
> # Limit to dwelling new builds, plus alterations cheap enough to look real
> dtPermit <- dtPermit[PropertyUse == "Dwelling Uses" & TypeOfWork %in% c("New Building","Addition / Alteration")]
> CRITQUANT <- .25
> qCrit <- quantile(dtPermit[TypeOfWork == "New Building" & SpecificUseCategory %in% c("Duplex","Single Detached House") & ProjectValue > 0, ProjectValue], CRITQUANT)
> dtPermit <- dtPermit[TypeOfWork == "New Building" | ProjectValue <= qCrit]
> dtPermit <- dtPermit[grepl("Duplex|Single Detached House|Laneway House|Multiple Dwelling",
+                            SpecificUseCategory)]
> 
> # Categorize by first word of SpecificUseCategory
> dtPermit[, useCat := tstrsplit(SpecificUseCategory, " ")[[1]]]
> dtPermit[, useCat := tstrsplit(useCat, ",")[[1]]]
> dtPermit[, year := as.numeric(substring(YearMonth, 1, 4))]
> print(table(dtPermit[, useCat]))

     Duplex    Dwelling      Infill     Laneway        Lock    Multiple 
       2099           3         216        4126          18        6062 
Residential   Secondary      Single 
          1          55        8130 
> 
> # Lat/lon
> dtPermit[, c("permitLat","permitLon") := tstrsplit(geo_point_2d, ", ")]
> dtPermit[, `:=`(permitLat = as.numeric(permitLat),
+                 permitLon = as.numeric(permitLon))]
> dtPermit <- dtPermit[!is.na(permitLat) & !is.na(permitLon)]
> 
> # Project down to columns we need downstream
> dtPermit <- dtPermit[, .(PermitNumber, useCat, year, permitLat, permitLon)]
> 
> # ============================================================================
> # ---- Spatial filters: R1-1 zoning, census tract, BCA parcel ---------------
> # ============================================================================
> 
> # R1-1 zoning polygon
> dZ <- st_read("~/DropboxExternal/dataRaw/vancouver_zoning.geojson")
Reading layer `vancouver_zoning' from data source 
  `/Volumes/Micron2TB/Dropbox/dataRaw/vancouver_zoning.geojson' 
  using driver `GeoJSON'
Simple feature collection with 1590 features and 6 fields
Geometry type: POLYGON
Dimension:     XY
Bounding box:  xmin: -123.2248 ymin: 49.19952 xmax: -123.0233 ymax: 49.31617
Geodetic CRS:  WGS 84
> dZ <- dZ[dZ$zoning_district == "R1-1", "zoning_district"]
> 
> # Census tract polygons
> stShp <- st_read("~/DropboxExternal/dataRaw/lct_000b21a_e/lct_000b21a_e.shp")
Reading layer `lct_000b21a_e' from data source 
  `/Volumes/Micron2TB/Dropbox/dataRaw/lct_000b21a_e/lct_000b21a_e.shp' 
  using driver `ESRI Shapefile'
Simple feature collection with 6247 features and 5 fields
Geometry type: MULTIPOLYGON
Dimension:     XY
Bounding box:  xmin: 3912489 ymin: 687427.7 xmax: 8996148 ymax: 2810992
Projected CRS: NAD83 / Statistics Canada Lambert
> stShp <- st_make_valid(stShp)
> stShp <- stShp[, "CTNAME"]
> 
> # BCA parcels (residential), reproject everything to BC Albers (3005)
> sfBCA <- st_as_sf(readRDS("~/DropboxExternal/dataProcessed/bca_vancouver_residential.rds"))
> sfBCA <- st_transform(sfBCA, 3005)
> dZ    <- st_transform(dZ,    3005)
> stShp <- st_transform(stShp, 3005)
> 
> # Add CTNAME to BCA
> sfBCA <- st_join(sfBCA, stShp, join = st_within)
> 
> # Extract BCA fields with parcel-level metric coords
> parcelCoords <- st_coordinates(st_centroid(st_geometry(sfBCA)))
> dtBCA <- as.data.table(st_drop_geometry(sfBCA))
> dtBCA[, `:=`(parcelXM = parcelCoords[,1], parcelYM = parcelCoords[,2])]
> 
> # Width/depth fallback from inventory if folioDescription missing
> dtBCA[, landWidth := as.numeric(landWidth)]
> dtBCA[, landDepth := as.numeric(landDepth)]
> if ("land_width"  %in% names(dtBCA)) dtBCA[is.na(landWidth), landWidth := as.numeric(land_width)]
> if ("land_depth"  %in% names(dtBCA)) dtBCA[is.na(landDepth), landDepth := as.numeric(land_depth)]
> 
> # Project BCA down to columns we need
> dtBCA <- dtBCA[, .(folioID, parcelXM, parcelYM, landWidth, landDepth, MB_total_finished_area, MB_effective_year, actualUseDescription, neighbourhoodDescription,
+                    CTNAME)]
> 
> # ---- Join permits to R1-1 and to BCA --------------------------------------
> sfPermit <- st_as_sf(dtPermit, coords = c("permitLon","permitLat"), crs = 4326)
> sfPermit <- st_transform(sfPermit, 3005)
> sfPermit <- st_join(sfPermit, dZ, join = st_intersects)
> sfPermit <- sfPermit[!is.na(sfPermit$zoning_district), ]
> sfPermit <- st_join(sfPermit, stShp, join = st_within)
> 
> # Permit metric coords
> permitCoords <- st_coordinates(st_geometry(sfPermit))
> dtPermit2 <- as.data.table(st_drop_geometry(sfPermit))
> dtPermit2[, `:=`(permitXM = permitCoords[,1], permitYM = permitCoords[,2])]
> 
> # Inherit neighbourhood and lot width from nearest BCA parcel
> sfPermitForJoin <- st_as_sf(dtPermit2, coords = c("permitXM","permitYM"),
+                             crs = 3005, remove = FALSE)
> dtBCAcoord <- dtBCA[!is.na(parcelXM) & !is.na(parcelYM)]
> cat("Dropped", nrow(dtBCA) - nrow(dtBCAcoord), "of", nrow(dtBCA),
+     "BCA rows with missing centroid\n")
Dropped 199 of 64210 BCA rows with missing centroid
> sfBCAforJoin <- st_as_sf(dtBCAcoord,
+                          coords = c("parcelXM","parcelYM"), crs = 3005,
+                          remove = FALSE)
> nearestIdx <- st_nearest_feature(sfPermitForJoin, sfBCAforJoin)
> dtPermit2[, neighbourhoodDescription := dtBCAcoord$neighbourhoodDescription[nearestIdx]]
> dtPermit2[, landWidth                := dtBCAcoord$landWidth[nearestIdx]]
> dtPermit2[, roundWidth               := round(landWidth)]
> print(names(dtPermit2))
 [1] "PermitNumber"             "useCat"                  
 [3] "year"                     "zoning_district"         
 [5] "CTNAME"                   "permitXM"                
 [7] "permitYM"                 "neighbourhoodDescription"
 [9] "landWidth"                "roundWidth"              
> q("no")
> proc.time()
   user  system elapsed 
  4.718   0.255   5.132 
