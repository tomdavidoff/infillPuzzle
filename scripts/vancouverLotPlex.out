+                 year >= 2018 & year < 2024,
+                 .(.N,
+                   medPriorAge   = median(priorAge, na.rm = TRUE),
+                   meanPriorAge  = mean(priorAge,   na.rm = TRUE),
+                   shareYoung    = mean(priorAge < 30, na.rm = TRUE),
+                   shareVeryYng  = mean(priorAge < 15, na.rm = TRUE)),
+                 by = useCat])
