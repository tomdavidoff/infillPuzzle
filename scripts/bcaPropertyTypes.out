23:               Vacant Residential Less Than 2 Acres   320 0.001533125
24:            Parking (Lot Only, Paved Or Gravel-Com)   313 0.001499588
25:                           Churches & Bible Schools   266 0.001274410
                                  actualUseDescription     N       share
                                                <char> <int>       <num>
> 
> use <- tab[share >= SHARE_FLOOR, actualUseDescription]
> hit <- function(pat) grep(pat, use, value = TRUE, ignore.case = TRUE)
> propertyTypeMap <- list(
+   singleFamily = setdiff(hit("single family|residential dwelling with suite"),
+                          hit("strata|duplex|condominium|apartment|multi")),
+   strata = setdiff(hit("strata|condominium|apartment"),
+                    hit("duplex|rental|commercial|hotel|block")),
+   duplex = hit("duplex")
+ )
> print(propertyTypeMap)
$singleFamily
[1] "Single Family Dwelling"          "Residential Dwelling with Suite"

$strata
[1] "Strata-Lot Residence (Condominium)"

$duplex
[1] "Duplex, Strata Front / Back" "Duplex, Strata Side by Side"

> for (nm in c("singleFamily", "strata", "duplex"))
+   cat(nm, "COV share:", tab[actualUseDescription %in% propertyTypeMap[[nm]], sum(share)], "\n")
singleFamily COV share: 0.3570361 
strata COV share: 0.4320538 
duplex COV share: 0.01986355 
> 
> saveRDS(propertyTypeMap, path.expand(MAP_OUT))
> 
> proc.time()
   user  system elapsed 
 14.754   0.600   6.786 
