4:        3836038     RS  278.142            86.84       1992
5:        5038161     RS  557.293            99.70       1964
6:        1452317     RS   91.251             0.00         NA
> 
> dtI <- dtI[year_built<2023]
> 
> dtM <- merge(dtA,dtI,by="Account Number")
> print(head(dtM))
Key: <Account Number>
   Account Number Assessed Value Assessment Year Latitude Longitude zoning
            <int>         <char>           <int>    <num>     <num> <char>
