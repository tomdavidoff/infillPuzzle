3:        1457910    $326,500.00            2018 53.54966 -113.5846
4:        1433606     $50,500.00            2019 53.55200 -113.6076
5:        1476985      $3,000.00            2012 53.54993 -113.5786
6:        1491398    $247,500.00            2018 53.55723 -113.5816
> dtA <- dtA[`Assessment Year`==2023]
> 
> dtI <- fread("~/DropboxExternal/dataRaw/edmonton/Property_Information_(Current_Calendar_Year)_20260612.csv",select=c("Account Number","zoning","lot_size","Total Gross Area","year_built"))
> dtI <- dtI[zoning=="RS"]
> print(head(dtI))
   Account Number zoning lot_size Total Gross Area year_built
            <int> <char>   <char>            <num>      <int>
1:        2460657     RS  645.037           101.66       1957
